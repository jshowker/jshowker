---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	id: string;
	title: string;
	tagline?: string;
	images: ImageMetadata[];
}

const { id, title, tagline, images } = Astro.props;
---

<section class="gallery-section" id={id} aria-labelledby={`${id}-heading`}>
	<div class="section-ambient" aria-hidden="true"></div>
	<div class="section-inner">
		<header class="section-head">
			<h2 class="section-title" id={`${id}-heading`}>{title}</h2>
			{tagline && <p class="section-tagline">{tagline}</p>}
		</header>
		<div class="masonry" role="list">
			{
				images.map((src, index) => (
					<figure class="card" role="listitem">
						<button
							type="button"
							class="card-trigger js-lightbox-thumb"
							aria-label={`View fullscreen — ${title} ${index + 1}`}
						>
							<span class="card-sheen" aria-hidden="true"></span>
							<span class="card-frame">
								<Image
									class="card-img"
									src={src}
									alt={`${title} — artwork ${index + 1}`}
									sizes="(max-width: 640px) 100vw, (max-width: 1200px) 50vw, 33vw"
									loading="lazy"
									decoding="async"
								/>
							</span>
						</button>
					</figure>
				))
			}
		</div>
	</div>
</section>

<style>
	.gallery-section {
		padding: clamp(3.5rem, 9vw, 7rem) clamp(1.25rem, 4vw, 3rem);
		position: relative;
		isolation: isolate;
		opacity: 0;
		transform: translate3d(0, 22px, 0);
		transition:
			opacity 1s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1)),
			transform 1.05s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1));
	}

	@media (prefers-reduced-motion: reduce) {
		.gallery-section {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}

	.gallery-section.is-revealed {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	.section-ambient {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background:
			radial-gradient(ellipse 90% 55% at 50% -5%, rgba(196, 165, 116, 0.09), transparent 58%),
			radial-gradient(ellipse 70% 50% at 100% 40%, rgba(100, 130, 200, 0.05), transparent 55%),
			radial-gradient(ellipse 60% 45% at 0% 70%, rgba(196, 165, 116, 0.04), transparent 50%);
		opacity: 0.85;
	}

	.section-ambient::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: min(45%, 420px);
		background: linear-gradient(to top, rgba(10, 11, 14, 0.55), transparent);
	}

	.section-inner {
		max-width: 1400px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.section-head {
		margin-bottom: clamp(1.75rem, 4vw, 2.75rem);
		text-align: center;
	}

	.section-title {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		background: linear-gradient(185deg, rgba(248, 250, 255, 0.98) 0%, rgba(180, 188, 205, 0.55) 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		filter: drop-shadow(0 0 42px rgba(196, 165, 116, 0.12));
	}

	.section-tagline {
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
		color: var(--text-faint);
		font-weight: 500;
	}

	.masonry {
		column-count: 1;
		column-gap: clamp(12px, 2vw, 20px);
	}

	@media (min-width: 560px) {
		.masonry {
			column-count: 2;
		}
	}

	@media (min-width: 1024px) {
		.masonry {
			column-count: 3;
		}
	}

	.card {
		margin: 0 0 clamp(12px, 2vw, 20px);
		break-inside: avoid;
		border-radius: var(--radius-md);
		position: relative;
		background: linear-gradient(
			160deg,
			rgba(255, 255, 255, 0.05) 0%,
			rgba(18, 21, 28, 0.95) 42%,
			rgba(12, 14, 18, 1) 100%
		);
		box-shadow:
			var(--shadow-card),
			0 0 0 1px rgba(255, 255, 255, 0.05) inset,
			0 1px 0 rgba(255, 255, 255, 0.06) inset,
			0 0 48px rgba(196, 165, 116, 0.04);
		transition:
			transform 0.65s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1)),
			box-shadow 0.65s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1)),
			filter 0.55s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1));
	}

	.card::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.07),
			inset 0 -1px 0 rgba(0, 0, 0, 0.25);
		pointer-events: none;
		opacity: 0.75;
		z-index: 2;
		transition: opacity 0.55s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1));
	}

	@media (prefers-reduced-motion: reduce) {
		.card {
			transition: none;
		}
	}

	.card:hover::before {
		opacity: 0.95;
	}

	.card:hover {
		transform: translateY(-6px);
		box-shadow:
			var(--shadow-soft),
			0 0 0 1px rgba(196, 165, 116, 0.12) inset,
			0 0 64px rgba(196, 165, 116, 0.1),
			0 0 100px rgba(90, 110, 160, 0.06);
		filter: saturate(1.03);
	}

	.card-trigger {
		display: block;
		width: 100%;
		margin: 0;
		padding: 0;
		border: none;
		background: transparent;
		border-radius: inherit;
		cursor: zoom-in;
		position: relative;
		overflow: hidden;
		text-align: left;
	}

	.card-trigger:focus-visible {
		outline: 2px solid rgba(196, 165, 116, 0.55);
		outline-offset: 3px;
	}

	.card-sheen {
		position: absolute;
		inset: 0;
		z-index: 3;
		pointer-events: none;
		background: linear-gradient(
			115deg,
			transparent 0%,
			rgba(255, 255, 255, 0) 38%,
			rgba(255, 255, 255, 0.06) 50%,
			rgba(255, 255, 255, 0) 62%,
			transparent 100%
		);
		transform: translateX(-120%);
		transition: transform 0.9s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1));
		opacity: 0.85;
	}

	.card:hover .card-sheen {
		transform: translateX(120%);
	}

	@media (prefers-reduced-motion: reduce) {
		.card-sheen {
			display: none;
		}
	}

	.card-frame {
		display: block;
		overflow: hidden;
		border-radius: calc(var(--radius-md) - 1px);
	}

	.card-img {
		width: 100%;
		height: auto;
		vertical-align: middle;
		transition: transform 0.85s var(--ease-premium, cubic-bezier(0.16, 1, 0.3, 1));
	}

	@media (prefers-reduced-motion: reduce) {
		.card-img {
			transition: none;
		}
	}

	.card:hover .card-img {
		transform: scale(1.045);
	}
</style>
