---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GallerySection from '../components/GallerySection.astro';
import { SITE_TITLE, SITE_DESCRIPTION, DISCORD_URL, TWITTER_URL } from '../consts';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
	'../PortfolioImg/**/*.{jpg,jpeg,png,webp}',
	{ eager: true }
);

function imagesInFolder(segment: string): ImageMetadata[] {
	return Object.entries(imageModules)
		.filter(([path]) => path.replace(/\\/g, '/').includes(`/PortfolioImg/${segment}/`))
		.map(([, mod]) => mod.default);
}

const characters = imagesInFolder('characters');
const armors = imagesInFolder('Armour');
const weapons = imagesInFolder('Weapon');
const misc = imagesInFolder('Misc');

const software = [
	'Substance Painter',
	'Photoshop',
	'3D Coat',
	'Blender',
	'ZBrush',
] as const;

const rates = [
	{ label: 'Weapons', value: '60+ USD' },
	{ label: 'Guns', value: '70+ USD' },
	{ label: 'Armors', value: '100+ USD' },
	{ label: 'Characters', value: '120+ USD' },
	{ label: 'Low / Mid Poly Assets', value: '30+ USD' },
	{ label: 'Hand-painted Textures', value: '60+ USD' },
	{ label: 'Rigging', value: '40+ USD' },
] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="noise" aria-hidden="true"></div>
		<Header />
		<main>
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-bg" aria-hidden="true"></div>
				<div class="hero-content">
					<p class="hero-eyebrow">3D Art</p>
					<h1 class="hero-title" id="hero-title">Jshowkerr</h1>
					<p class="hero-sub">Experienced 3D Artist with 4+ years of experience</p>
					<p class="hero-desc">
						Specialized in stylized and hand-painted 3D models of any complexity.
					</p>

					<ul class="software" aria-label="Software">
						{software.map((name) => <li>{name}</li>)}
					</ul>

					<div class="hero-lower">
						<div class="pricing" aria-labelledby="pricing-heading">
							<div class="pricing-glow" aria-hidden="true"></div>
							<h2 class="pricing-title" id="pricing-heading">Commission rates</h2>
							<p class="pricing-start">Starting at <strong>20 USD</strong>.</p>
							<p class="pricing-sub">Average rates</p>
							<ul class="rate-list">
								{
									rates.map(({ label, value }) => (
										<li>
											<span class="rate-label">{label}</span>
											<span class="rate-value">{value}</span>
										</li>
									))
								}
							</ul>
							<p class="pricing-note">
								If references are not included for personal designs, extra charges of 30 USD per
								item apply.
							</p>
						</div>

						<div class="links-block" id="links">
							<h2 class="links-heading">Connect</h2>
							<ul class="links-list">
								<li>
									<a href={DISCORD_URL} target="_blank" rel="noopener noreferrer">Discord</a>
								</li>
								<li>
									<a href={TWITTER_URL} target="_blank" rel="noopener noreferrer">Twitter</a>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<div id="work" class="work-anchor" aria-hidden="true"></div>

			{
				characters.length > 0 && (
					<GallerySection
						id="characters"
						title="Characters"
						tagline="Stylized figures & portraits"
						images={characters}
					/>
				)
			}
			{
				armors.length > 0 && (
					<GallerySection
						id="armors"
						title="Armors"
						tagline="Wearables & gear"
						images={armors}
					/>
				)
			}
			{
				weapons.length > 0 && (
					<GallerySection
						id="weapons"
						title="Weapons"
						tagline="Props & firearms"
						images={weapons}
					/>
				)
			}
			{
				misc.length > 0 && (
					<GallerySection id="misc" title="Misc" tagline="Additional work" images={misc} />
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.noise {
		pointer-events: none;
		position: fixed;
		inset: 0;
		z-index: 9999;
		opacity: 0.035;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
	}

	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(6rem, 12vw, 9rem) clamp(1.25rem, 4vw, 2.5rem) clamp(3rem, 6vw, 5rem);
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 100% 80% at 50% -20%, rgba(196, 165, 116, 0.08), transparent 50%),
			radial-gradient(ellipse 60% 40% at 80% 60%, rgba(90, 110, 160, 0.06), transparent 45%),
			linear-gradient(180deg, var(--bg-deep) 0%, var(--bg-elevated) 100%);
	}

	.hero-bg::after {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
		background-size: 64px 64px;
		mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black, transparent);
	}

	.hero-content {
		position: relative;
		z-index: 1;
		max-width: 720px;
		margin: 0 auto;
		text-align: center;
	}

	.hero-eyebrow {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 1.25rem;
	}

	.hero-title {
		font-size: clamp(2.75rem, 10vw, 4.75rem);
		font-weight: 800;
		letter-spacing: 0.02em;
		line-height: 1;
		margin: 0 0 1rem;
		text-shadow: 0 0 80px var(--accent-glow);
	}

	.hero-sub {
		font-size: clamp(1rem, 2.2vw, 1.2rem);
		color: var(--text-muted);
		font-weight: 500;
		margin: 0 0 0.75rem;
	}

	.hero-desc {
		font-size: clamp(0.95rem, 1.8vw, 1.05rem);
		color: var(--text-faint);
		max-width: 34em;
		margin: 0 auto 2rem;
		line-height: 1.7;
	}

	.software {
		list-style: none;
		margin: 0 auto 2.5rem;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem 0.65rem;
		max-width: 36rem;
	}

	.software li {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		padding: 0.45rem 0.85rem;
		border-radius: 999px;
		background: var(--surface);
		border: 1px solid var(--border);
	}

	.hero-lower {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1.5rem, 4vw, 2rem);
		align-items: start;
		text-align: left;
	}

	@media (min-width: 720px) {
		.hero-lower {
			grid-template-columns: 1.15fr 0.85fr;
			align-items: stretch;
		}
	}

	.pricing {
		position: relative;
		padding: clamp(1.35rem, 3vw, 1.75rem);
		border-radius: var(--radius-lg);
		background: var(--surface);
		border: 1px solid var(--border);
		box-shadow: var(--shadow-card);
		overflow: hidden;
	}

	.pricing-glow {
		position: absolute;
		top: -40%;
		right: -20%;
		width: 55%;
		height: 80%;
		background: radial-gradient(circle, var(--accent-glow), transparent 70%);
		opacity: 0.35;
		pointer-events: none;
	}

	.pricing-title {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 0.75rem;
		position: relative;
	}

	.pricing-start {
		font-size: 1.15rem;
		color: var(--text);
		margin: 0 0 1rem;
		position: relative;
	}

	.pricing-start strong {
		color: var(--accent);
		font-weight: 700;
	}

	.pricing-sub {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--text-faint);
		margin: 0 0 0.75rem;
		position: relative;
	}

	.rate-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		position: relative;
	}

	.rate-list li {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding: 0.55rem 0;
		border-bottom: 1px solid var(--border);
		font-size: 0.9rem;
	}

	.rate-list li:last-of-type {
		border-bottom: none;
	}

	.rate-label {
		color: var(--text-muted);
	}

	.rate-value {
		font-weight: 600;
		color: var(--text);
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.pricing-note {
		margin: 1.1rem 0 0;
		font-size: 0.78rem;
		line-height: 1.55;
		color: var(--text-faint);
		position: relative;
	}

	.links-block {
		padding: clamp(1.35rem, 3vw, 1.75rem);
		border-radius: var(--radius-lg);
		background: rgba(17, 19, 24, 0.6);
		border: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.links-heading {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 1rem;
	}

	.links-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.links-list a {
		display: block;
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--text);
		padding: 0.5rem 0;
		border-bottom: 1px solid var(--border);
		transition:
			color 0.25s var(--ease-out),
			padding-left 0.35s var(--ease-out),
			border-color 0.25s var(--ease-out);
	}

	.links-list a:hover {
		color: var(--accent);
		padding-left: 0.35rem;
		border-color: rgba(196, 165, 116, 0.35);
	}

	.work-anchor {
		height: 0;
		scroll-margin-top: 5rem;
	}

	:global(.gallery-section) {
		scroll-margin-top: 5rem;
	}
</style>
