---
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GallerySection from '../components/GallerySection.astro';
import Lightbox from '../components/Lightbox.astro';
import { SITE_TITLE, SITE_DESCRIPTION, DISCORD_URL, TWITTER_URL } from '../consts';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
	'../PortfolioImg/**/*.{jpg,jpeg,png,webp}',
	{ eager: true }
);

function imagesInFolder(segment: string): ImageMetadata[] {
	return Object.entries(imageModules)
		.filter(([path]) => path.replace(/\\/g, '/').includes(`/PortfolioImg/${segment}/`))
		.map(([, mod]) => mod.default);
}

const characters = imagesInFolder('characters');
const armors = imagesInFolder('Armour');
const weapons = imagesInFolder('Weapon');
const misc = imagesInFolder('Misc');

const software = [
	'Substance Painter',
	'Photoshop',
	'3D Coat',
	'Blender',
	'ZBrush',
] as const;

const rates = [
	{ label: 'Weapons', value: '60+ USD' },
	{ label: 'Guns', value: '70+ USD' },
	{ label: 'Armors', value: '100+ USD' },
	{ label: 'Characters', value: '120+ USD' },
	{ label: 'Low / Mid Poly Assets', value: '30+ USD' },
	{ label: 'Hand-painted Textures', value: '60+ USD' },
	{ label: 'Rigging', value: '40+ USD' },
] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<div class="noise" aria-hidden="true"></div>
		<canvas id="dust-canvas" class="dust-canvas" aria-hidden="true"></canvas>
		<Header />
		<main>
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-bg" aria-hidden="true">
					<div class="hero-orb hero-orb-a"></div>
					<div class="hero-orb hero-orb-b"></div>
					<div class="hero-parallax" aria-hidden="true">
						<div class="hero-parallax-inner"></div>
					</div>
					<div class="hero-grid" aria-hidden="true"></div>
					<div class="hero-fog" aria-hidden="true"></div>
				</div>
				<div class="hero-content">
					<p class="hero-eyebrow">3D Art</p>
					<h1 class="hero-title" id="hero-title">Jshowkerr</h1>
					<p class="hero-sub">Experienced 3D Artist with 4+ years of experience</p>
					<p class="hero-desc">
						Specialized in stylized and hand-painted 3D models of any complexity.
					</p>

					<ul class="software" aria-label="Software">
						{software.map((name) => <li>{name}</li>)}
					</ul>

					<div class="hero-lower">
						<div class="pricing" aria-labelledby="pricing-heading">
							<div class="pricing-glow" aria-hidden="true"></div>
							<h2 class="pricing-title" id="pricing-heading">Commission rates</h2>
							<p class="pricing-start">Starting at <strong>20 USD</strong>.</p>
							<p class="pricing-sub">Average rates</p>
							<ul class="rate-list">
								{
									rates.map(({ label, value }) => (
										<li>
											<span class="rate-label">{label}</span>
											<span class="rate-value">{value}</span>
										</li>
									))
								}
							</ul>
							<p class="pricing-note">
								If references are not included for personal designs, extra charges of 30 USD per
								item apply.
							</p>
						</div>

						<div class="links-block" id="links">
							<h2 class="links-heading">Connect</h2>
							<ul class="links-list">
								<li>
									<a href={DISCORD_URL} target="_blank" rel="noopener noreferrer">Discord</a>
								</li>
								<li>
									<a href={TWITTER_URL} target="_blank" rel="noopener noreferrer">Twitter</a>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<div id="work" class="work-anchor" aria-hidden="true"></div>

			{
				characters.length > 0 && (
					<GallerySection
						id="characters"
						title="Characters"
						tagline="Stylized figures & portraits"
						images={characters}
					/>
				)
			}
			{
				armors.length > 0 && (
					<GallerySection
						id="armors"
						title="Armors"
						tagline="Wearables & gear"
						images={armors}
					/>
				)
			}
			{
				weapons.length > 0 && (
					<GallerySection
						id="weapons"
						title="Weapons"
						tagline="Props & firearms"
						images={weapons}
					/>
				)
			}
			{
				misc.length > 0 && (
					<GallerySection id="misc" title="Misc" tagline="Additional work" images={misc} />
				)
			}
		</main>
		<Footer />
		<Lightbox />
		<script>
			import { initPortfolioClient } from '../scripts/portfolio-client';
			initPortfolioClient();
		</script>
		<noscript>
			<style is:global>
				.gallery-section {
					opacity: 1 !important;
					transform: none !important;
				}
			</style>
		</noscript>
	</body>
</html>

<style>
	.noise {
		pointer-events: none;
		position: fixed;
		inset: 0;
		z-index: 9998;
		opacity: 0.042;
		mix-blend-mode: overlay;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
	}

	.dust-canvas {
		position: fixed;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		opacity: 0.38;
	}

	@media (prefers-reduced-motion: reduce) {
		.dust-canvas {
			display: none;
		}
	}

	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: clamp(6rem, 12vw, 9rem) clamp(1.25rem, 4vw, 2.5rem) clamp(3rem, 6vw, 5rem);
		overflow: hidden;
	}

	.hero-bg {
		--scroll-shift: 0;
		position: absolute;
		inset: -12%;
		background:
			radial-gradient(ellipse 100% 85% at 50% -15%, rgba(196, 165, 116, 0.11), transparent 52%),
			radial-gradient(ellipse 55% 45% at 85% 55%, rgba(95, 120, 190, 0.09), transparent 50%),
			radial-gradient(ellipse 50% 40% at 10% 65%, rgba(196, 165, 116, 0.05), transparent 48%),
			linear-gradient(195deg, #0c0d12 0%, var(--bg-deep) 38%, #07080b 100%);
		transform: translate3d(0, calc(var(--scroll-shift) * 36px), 0);
		transition: transform 0.75s var(--ease-premium);
		overflow: hidden;
	}

	.hero-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.55;
		pointer-events: none;
		mix-blend-mode: screen;
	}

	.hero-orb-a {
		width: min(55vw, 520px);
		height: min(55vw, 520px);
		top: -18%;
		left: 50%;
		transform: translateX(-50%);
		background: radial-gradient(circle at 40% 40%, rgba(196, 165, 116, 0.35), transparent 65%);
		animation: orb-drift-a 22s ease-in-out infinite alternate;
	}

	.hero-orb-b {
		width: min(70vw, 640px);
		height: min(70vw, 640px);
		bottom: -28%;
		right: -12%;
		background: radial-gradient(circle at 50% 50%, rgba(80, 110, 180, 0.22), transparent 68%);
		animation: orb-drift-b 26s ease-in-out infinite alternate;
	}

	@keyframes orb-drift-a {
		0% {
			transform: translateX(-50%) translateY(0) scale(1);
		}
		100% {
			transform: translateX(-52%) translateY(18px) scale(1.06);
		}
	}

	@keyframes orb-drift-b {
		0% {
			transform: translate(0, 0) scale(1);
		}
		100% {
			transform: translate(-24px, -14px) scale(1.05);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-orb-a,
		.hero-orb-b {
			animation: none;
		}
	}

	.hero-parallax {
		position: absolute;
		inset: -8%;
		pointer-events: none;
		will-change: transform;
	}

	.hero-parallax-inner {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 80% 60% at 50% 40%, rgba(255, 255, 255, 0.04), transparent 62%),
			radial-gradient(ellipse 120% 80% at 50% 120%, rgba(0, 0, 0, 0.35), transparent 45%);
		opacity: 0.9;
	}

	.hero-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.018) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
		background-size: 72px 72px;
		mask-image: radial-gradient(ellipse 72% 58% at 50% 32%, black, transparent 72%);
		opacity: 0.85;
		pointer-events: none;
	}

	.hero-fog {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 42%;
		background: linear-gradient(to top, rgba(5, 6, 9, 0.85), transparent);
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 2;
		max-width: 720px;
		margin: 0 auto;
		text-align: center;
	}

	.hero-eyebrow {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 1.25rem;
		text-shadow: 0 0 28px rgba(196, 165, 116, 0.35);
	}

	.hero-title {
		font-size: clamp(2.75rem, 10vw, 4.75rem);
		font-weight: 800;
		letter-spacing: 0.02em;
		line-height: 1;
		margin: 0 0 1rem;
		text-shadow:
			0 0 100px rgba(196, 165, 116, 0.22),
			0 0 1px rgba(0, 0, 0, 0.5);
	}

	@media (prefers-reduced-motion: no-preference) {
		@keyframes hero-title-breathe {
			0%,
			100% {
				text-shadow:
					0 0 90px rgba(196, 165, 116, 0.18),
					0 0 1px rgba(0, 0, 0, 0.5);
			}
			50% {
				text-shadow:
					0 0 120px rgba(196, 165, 116, 0.28),
					0 0 1px rgba(0, 0, 0, 0.5);
			}
		}
		.hero-title {
			animation: hero-title-breathe 9s ease-in-out infinite;
		}
	}

	.hero-sub {
		font-size: clamp(1rem, 2.2vw, 1.2rem);
		color: var(--text-muted);
		font-weight: 500;
		margin: 0 0 0.75rem;
	}

	.hero-desc {
		font-size: clamp(0.95rem, 1.8vw, 1.05rem);
		color: var(--text-faint);
		max-width: 34em;
		margin: 0 auto 2rem;
		line-height: 1.7;
	}

	.software {
		list-style: none;
		margin: 0 auto 2.5rem;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem 0.65rem;
		max-width: 36rem;
	}

	.software li {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		padding: 0.45rem 0.85rem;
		border-radius: 999px;
		background: linear-gradient(165deg, rgba(30, 34, 44, 0.95), rgba(18, 20, 26, 0.98));
		border: 1px solid rgba(255, 255, 255, 0.06);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35) inset,
			0 1px 0 rgba(255, 255, 255, 0.05) inset;
		transition:
			transform 0.55s var(--ease-premium),
			border-color 0.55s var(--ease-premium),
			box-shadow 0.55s var(--ease-premium),
			color 0.45s var(--ease-premium);
	}

	.software li:hover {
		transform: translateY(-2px);
		border-color: rgba(196, 165, 116, 0.22);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.35) inset,
			0 1px 0 rgba(255, 255, 255, 0.06) inset,
			0 12px 36px rgba(0, 0, 0, 0.35),
			0 0 28px rgba(196, 165, 116, 0.08);
		color: rgba(232, 234, 239, 0.78);
	}

	@media (prefers-reduced-motion: reduce) {
		.software li {
			transition: none;
		}
		.software li:hover {
			transform: none;
		}
	}

	.hero-lower {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1.5rem, 4vw, 2rem);
		align-items: start;
		text-align: left;
	}

	@media (min-width: 720px) {
		.hero-lower {
			grid-template-columns: 1.15fr 0.85fr;
			align-items: stretch;
		}
	}

	.pricing {
		position: relative;
		padding: clamp(1.35rem, 3vw, 1.75rem);
		border-radius: var(--radius-lg);
		background: linear-gradient(
			168deg,
			rgba(255, 255, 255, 0.05) 0%,
			rgba(20, 23, 31, 0.96) 42%,
			rgba(14, 16, 22, 1) 100%
		);
		border: 1px solid rgba(255, 255, 255, 0.06);
		box-shadow:
			var(--shadow-card),
			0 0 0 1px rgba(0, 0, 0, 0.35) inset,
			0 1px 0 rgba(255, 255, 255, 0.06) inset,
			0 0 60px rgba(196, 165, 116, 0.05);
		overflow: hidden;
		transition:
			box-shadow 0.65s var(--ease-premium),
			transform 0.65s var(--ease-premium);
		isolation: isolate;
	}

	.pricing:hover {
		transform: translateY(-2px);
		box-shadow:
			var(--shadow-soft),
			0 0 0 1px rgba(0, 0, 0, 0.35) inset,
			0 1px 0 rgba(255, 255, 255, 0.07) inset,
			0 0 72px rgba(196, 165, 116, 0.08);
	}

	@media (prefers-reduced-motion: reduce) {
		.pricing {
			transition: none;
		}
		.pricing:hover {
			transform: none;
		}
	}

	.pricing::after {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: linear-gradient(105deg, rgba(255, 255, 255, 0.07) 0%, transparent 38%);
		opacity: 0.22;
		pointer-events: none;
		mix-blend-mode: soft-light;
		z-index: 0;
	}

	.pricing-glow {
		position: absolute;
		top: -40%;
		right: -20%;
		width: 55%;
		height: 80%;
		background: radial-gradient(circle, var(--accent-glow), transparent 70%);
		opacity: 0.35;
		pointer-events: none;
		z-index: 0;
	}

	.pricing > *:not(.pricing-glow) {
		position: relative;
		z-index: 1;
	}

	.pricing-title {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 0.75rem;
		position: relative;
	}

	.pricing-start {
		font-size: 1.15rem;
		color: var(--text);
		margin: 0 0 1rem;
		position: relative;
	}

	.pricing-start strong {
		color: var(--accent);
		font-weight: 700;
	}

	.pricing-sub {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--text-faint);
		margin: 0 0 0.75rem;
		position: relative;
	}

	.rate-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		position: relative;
	}

	.rate-list li {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding: 0.55rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		font-size: 0.9rem;
		box-shadow: 0 1px 0 rgba(255, 255, 255, 0.02);
	}

	.rate-list li:last-of-type {
		border-bottom: none;
	}

	.rate-label {
		color: var(--text-muted);
	}

	.rate-value {
		font-weight: 600;
		color: var(--text);
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.pricing-note {
		margin: 1.1rem 0 0;
		font-size: 0.78rem;
		line-height: 1.55;
		color: var(--text-faint);
		position: relative;
	}

	.links-block {
		padding: clamp(1.35rem, 3vw, 1.75rem);
		border-radius: var(--radius-lg);
		background: linear-gradient(
			195deg,
			rgba(255, 255, 255, 0.04) 0%,
			rgba(16, 18, 24, 0.88) 45%,
			rgba(10, 11, 15, 0.95) 100%
		);
		border: 1px solid rgba(255, 255, 255, 0.06);
		display: flex;
		flex-direction: column;
		justify-content: center;
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.3) inset,
			0 1px 0 rgba(255, 255, 255, 0.05) inset,
			0 24px 64px rgba(0, 0, 0, 0.28);
		transition:
			box-shadow 0.65s var(--ease-premium),
			transform 0.65s var(--ease-premium);
	}

	.links-block:hover {
		transform: translateY(-2px);
		box-shadow:
			0 0 0 1px rgba(0, 0, 0, 0.3) inset,
			0 1px 0 rgba(255, 255, 255, 0.06) inset,
			0 32px 80px rgba(0, 0, 0, 0.35),
			0 0 48px rgba(196, 165, 116, 0.06);
	}

	@media (prefers-reduced-motion: reduce) {
		.links-block {
			transition: none;
		}
		.links-block:hover {
			transform: none;
		}
	}

	.links-heading {
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin: 0 0 1rem;
	}

	.links-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.links-list a {
		display: block;
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--text);
		padding: 0.5rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		transition:
			color 0.45s var(--ease-premium),
			padding-left 0.55s var(--ease-premium),
			border-color 0.45s var(--ease-premium),
			letter-spacing 0.55s var(--ease-premium);
	}

	.links-list a:hover {
		color: var(--accent);
		padding-left: 0.35rem;
		border-color: rgba(196, 165, 116, 0.35);
		letter-spacing: 0.02em;
	}

	.work-anchor {
		height: 0;
		scroll-margin-top: 5rem;
	}

	:global(.gallery-section) {
		scroll-margin-top: 5rem;
	}
</style>
